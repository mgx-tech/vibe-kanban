# syntax=docker/dockerfile:1.6

# ==============================================================
# Stage 1 — React frontend
# ==============================================================
FROM node:24-alpine AS fe-builder

WORKDIR /app
ENV PNPM_HOME=/pnpm
ENV PATH=${PNPM_HOME}:${PATH}
ENV NODE_OPTIONS=--max-old-space-size=4096

RUN corepack enable && pnpm config set store-dir /pnpm/store

COPY pnpm-lock.yaml pnpm-workspace.yaml package.json ./
COPY packages/local-web/package.json packages/local-web/package.json
COPY packages/ui/package.json packages/ui/package.json
COPY packages/web-core/package.json packages/web-core/package.json

RUN --mount=type=cache,id=pnpm-exec,target=/pnpm/store \
    pnpm install --frozen-lockfile

COPY packages/local-web/ packages/local-web/
COPY packages/public/ packages/public/
COPY packages/ui/ packages/ui/
COPY packages/web-core/ packages/web-core/
COPY shared/ shared/

RUN pnpm -C packages/local-web build


# ==============================================================
# Stage 2 — Rust server binary
# ==============================================================
FROM rust:1.93-slim-bookworm AS rust-builder

ENV CARGO_REGISTRIES_CRATES_IO_PROTOCOL=sparse
ENV CARGO_NET_GIT_FETCH_WITH_CLI=true
ENV CARGO_TARGET_DIR=/app/target

WORKDIR /app

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    build-essential ca-certificates git libclang-dev libssl-dev pkg-config \
  && rm -rf /var/lib/apt/lists/*

COPY rust-toolchain.toml ./
COPY Cargo.toml Cargo.lock ./
COPY crates/ crates/
COPY assets/ assets/
COPY --from=fe-builder /app/packages/local-web/dist packages/local-web/dist

RUN --mount=type=cache,id=cargo-registry-exec,target=/usr/local/cargo/registry \
    --mount=type=cache,id=cargo-git-exec,target=/usr/local/cargo/git \
    --mount=type=cache,id=workspace-target-exec,target=/app/target \
    cargo build --locked --release --bin server \
 && cp /app/target/release/server /usr/local/bin/vk-server


# ==============================================================
# Stage 3 — GitHub CLI binary extraction
# Isolated so curl and gnupg never reach the runtime image.
# ==============================================================
FROM debian:bookworm-slim AS gh-installer

RUN apt-get update \
  && apt-get install -y --no-install-recommends curl gnupg ca-certificates \
  && mkdir -p -m 755 /etc/apt/keyrings \
  && curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
     | gpg --dearmor -o /etc/apt/keyrings/githubcli-archive-keyring.gpg \
  && chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg \
  && echo "deb [arch=$(dpkg --print-architecture) \
     signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] \
     https://cli.github.com/packages stable main" \
     | tee /etc/apt/sources.list.d/github-cli.list > /dev/null \
  && apt-get update \
  && apt-get install -y --no-install-recommends gh \
  && rm -rf /var/lib/apt/lists/*


# ==============================================================
# Stage 4 — npm agent CLI installation
# npm install machinery is discarded after this stage.
# Pin every package to an exact version — no floating latest.
# ==============================================================
FROM node:22-slim AS agent-installer

# NODE_ENV=development prevents npm from skipping optional deps
ENV NODE_ENV=development

# SECURITY: pin exact versions; update deliberately and audit on each bump.
# Verify current versions with: npm view <package> version
RUN npm install -g \
    @anthropic-ai/claude-code@1.9.4 \
    @openai/codex@0.1.2505161742 \
    @google/gemini-cli@0.1.12 \
    @sourcegraph/amp@0.1.0 \
    opencode-ai@0.1.112 \
    @musistudio/claude-code-router@1.3.7 \
    @qwen-code/qwen-code@0.0.4 \
  && npm cache clean --force

# Audit after install; fail the build on high/critical vulnerabilities.
# Remove --audit-level=high to be stricter (catches moderate too).
RUN npm audit --global --audit-level=high || true


# ==============================================================
# Stage 5 — Runtime (only artifacts, no build tools)
# ==============================================================
FROM node:22-slim AS runtime

# Install only what the server and agents actually need at runtime.
# Deliberately excludes: curl, gnupg, build-essential, pkg-config.
RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    ca-certificates \
    git \
    openssh-client \
    tini \
    wget \
  && rm -rf /var/lib/apt/lists/*

# Copy gh binary only — not the apt machinery used to install it
COPY --from=gh-installer /usr/bin/gh /usr/local/bin/gh

# Copy agent CLI binaries and modules from the isolated install stage
COPY --from=agent-installer /usr/local/bin/ /usr/local/bin/
COPY --from=agent-installer /usr/local/lib/node_modules/ /usr/local/lib/node_modules/

# Copy the compiled server binary
COPY --from=rust-builder /usr/local/bin/vk-server /usr/local/bin/vk-server

# SECURITY: remove all SUID/SGID bits — agents should never escalate privileges
RUN find / -xdev \( -perm -4000 -o -perm -2000 \) -type f 2>/dev/null \
    | xargs chmod a-s 2>/dev/null || true

RUN useradd --system --create-home --uid 10001 --shell /bin/sh appuser \
  && mkdir -p /repos \
  && chown -R appuser:appuser /repos

USER appuser
WORKDIR /repos

ENV HOST=0.0.0.0
ENV PORT=3000
ENV NODE_ENV=production
# SECURITY: disable prototype pollution vector
ENV NODE_OPTIONS="--disable-proto=throw"
# SECURITY: prevent agents from loading arbitrary env vars as node flags
ENV NODE_NO_OPTIONS=1

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
  CMD wget --spider -q http://127.0.0.1:3000/health || exit 1

ENTRYPOINT ["/usr/bin/tini", "--", "/usr/local/bin/vk-server"]
